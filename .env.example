# Polygon RPC (any provider — Alchemy, Infura, public RPC, ...)
POLYGON_RPC_URL=https://polygon.drpc.org

# EOA private key (0x...). MUST be the owner of the Polymarket wallet (DepositWallet or Safe proxy)
# that holds the CT tokens. NEVER commit this to git.
EOA_PRIVATE_KEY=0x...

#Credentials for using the Polymarket relayer. Create them at https://polymarket.com/de/settings?tab=relayer-api-keys
POLY_BUILDER_API_KEY=""
POLY_BUILDER_PASSPHRASE=""
POLY_BUILDER_SECRET=""

# Optional: override the Robin API base URL (TWAP proxy + the read-only Integration API /api/v1).
# ROBIN_API_BASE=https://app.robin.markets/api